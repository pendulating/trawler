#!/bin/bash
#SBATCH --job-name=qwen25-72b-llm
#SBATCH --partition=pierson
#SBATCH --gres=gpu:2               # Qwen3-30B typically requires ≥2 A6000/A40 GPUs
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=48:00:00
#SBATCH --output=logs/qwen25-72b-llm-%j.out
#SBATCH --error=logs/qwen25-72b-llm-%j.err

set -euo pipefail

echo "=== Qwen25-72B LLM Server ==="
date
echo ""

# ----------------------------- CONFIGURATION ----------------------------- #
REPO_DIR="/share/pierson/matt/UAIR"
MODEL_PATH="${MODEL_PATH:-/share/pierson/matt/zoo/models/Qwen2.5-72B-Instruct-AWQ}"
PORT="${PORT:-8924}"
HOST="${HOST:-0.0.0.0}"
TP_SIZE="${TP_SIZE:-2}"          # Tensor-parallel workers (match number of GPUs requested)
CONCURRENCY="${CONCURRENCY:-1}"
GPU_MEM_UTIL="${GPU_MEM_UTIL:-0.90}"
MAX_MODEL_LEN="${MAX_MODEL_LEN:-32768}"    # 32k context for GEPA reflection (native: 262k)
MAX_BATCHED_TOKENS="${MAX_BATCHED_TOKENS:-8192}"
HF_HOME="${HF_HOME:-/share/pierson/matt/.cache/huggingface}"
LOG_DIR="${LOG_DIR:-$REPO_DIR/logs/vllm}"
RUN_NAME="${RUN_NAME:-qwen25-72b-llm}"


mkdir -p "$LOG_DIR"
mkdir -p "$HF_HOME"

echo "Repository      : $REPO_DIR"
echo "Model path      : $MODEL_PATH"
echo "HF cache        : $HF_HOME"
echo "Host / Port     : $HOST:$PORT"
echo "TP size         : $TP_SIZE"
echo "Concurrency     : $CONCURRENCY"
echo "GPU util target : $GPU_MEM_UTIL"
echo ""

# ------------------------------ ENVIRONMENT ------------------------------ #
# Activate virtual environment FIRST before any Python commands
cd "$REPO_DIR"
pwd

if [ ! -d ".venv" ]; then
    echo "ERROR: .venv not found. Create the uv virtualenv before submitting this job." >&2
    exit 1
fi

# Activate venv before running any Python
source .venv/bin/activate
echo "Python: $(which python)"
echo "Python version: $(python --version)"

# ------------------------------ GPU SANITY ------------------------------- #
if ! command -v nvidia-smi >/dev/null 2>&1; then
    echo "ERROR: nvidia-smi not found. Ensure this job runs on a GPU node." >&2
    exit 1
fi

nvidia-smi
nvidia-smi topo -m || true

# Now safe to run Python checks (using venv Python)
python -c 'import torch; print("torch.cuda.is_available=", torch.cuda.is_available()); print("torch.cuda.device_count=", torch.cuda.device_count()); [print(f"torch device {i}=", torch.cuda.get_device_name(i)) for i in range(torch.cuda.device_count())]'

if ! command -v vllm >/dev/null 2>&1; then
    echo "ERROR: vllm CLI not found in the current environment." >&2
    exit 1
fi

export HF_HOME
export WANDB_MODE=disabled          # Disable W&B for this background service
export VLLM_WORKER_MULTIPROC_METHOD=spawn
export VLLM_USE_V1=1
export VLLM_ENABLE_V1_MULTIPROCESSING=0
export VLLM_TARGET_DEVICE=cuda  
export VLLM_LOGGING_LEVEL=DEBUG
export PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:64,expandable_segments:True
export CUDA_LAUNCH_BLOCKING=0
export TOKENIZERS_PARALLELISM=false
# Respect Slurm's per-step GPU mapping if present. Otherwise, only propagate
# SLURM_JOB_GPUS when it already contains CUDA-style indices (e.g. "0,1").
if [ -z "${CUDA_VISIBLE_DEVICES:-}" ]; then
    if [ -n "${SLURM_STEP_GPUS:-}" ]; then
        export CUDA_VISIBLE_DEVICES="${SLURM_STEP_GPUS}"
    elif [ -n "${SLURM_JOB_GPUS:-}" ]; then
        if [[ "${SLURM_JOB_GPUS}" =~ ^[0-9]+(,[0-9]+)*$ ]]; then
            export CUDA_VISIBLE_DEVICES="${SLURM_JOB_GPUS}"
        else
            echo "WARNING: Ignoring SLURM_JOB_GPUS='${SLURM_JOB_GPUS}' (not CUDA indices)" >&2
        fi
    fi
fi

echo "SLURM_JOB_GPUS=${SLURM_JOB_GPUS:-<unset>}"
echo "SLURM_STEP_GPUS=${SLURM_STEP_GPUS:-<unset>}"
echo "CUDA_VISIBLE_DEVICES=${CUDA_VISIBLE_DEVICES:-<unset>}"

echo "Checking if CUDA devices can access each other..."
python - <<'PY'
import torch
print(torch.cuda.can_device_access_peer(0, 1))
PY

# ------------------------------ LAUNCH VLLM ------------------------------ #

echo "Starting vLLM server..."
echo ""

CMD=(
    vllm serve "$MODEL_PATH"
    --host "$HOST"
    --port "$PORT"
    --tensor-parallel-size "$TP_SIZE"
    --max-model-len "$MAX_MODEL_LEN"
    --max-num-batched-tokens "$MAX_BATCHED_TOKENS"
    --gpu-memory-utilization "$GPU_MEM_UTIL"
    --trust-remote-code
    --enable-chunked-prefill
    --max-num-seqs "$CONCURRENCY"
    --served-model-name "$RUN_NAME"
    --disable-log-requests
    --disable-custom-all-reduce
)

echo "Command line:"
printf '  %q\n' "${CMD[@]}"
echo ""

# Use srun so the process is tracked by SLURM.
srun --ntasks=1 --gpus-per-task="${TP_SIZE}" "${CMD[@]}"

echo ""
echo "vLLM server exited at $(date)"

